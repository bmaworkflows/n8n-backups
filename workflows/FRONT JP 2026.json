    {
      "parameters": {
        "jsCode": "// n8n Function node\n// Lê data.purchase.origin.sck e gera os campos UTM no item de saída\n\nconst UTM_KEYS = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];\n\nreturn items.map(({ json, binary }) => {\n  // Pega o sck (garante string) e faz URL-decode\n  const rawSck = (json?.data?.purchase?.origin?.sck ?? '') + '';\n  const decoded = decodeURIComponent(rawSck).trim();\n\n  // Se vier algo no formato \"...?x=1&sck=foo|bar\", tenta extrair \"sck=\" da query também\n  let sckValue = decoded;\n  if (decoded.includes('sck=')) {\n    try {\n      const q = decoded.split('?')[1] || decoded;\n      const pairs = q.split('&');\n      const found = pairs.find(p => p.startsWith('sck='));\n      if (found) sckValue = decodeURIComponent(found.split('=')[1] || '');\n    } catch (_) {}\n  }\n\n  // Quebra pelos pipes e normaliza\n  const parts = sckValue.split('|').map(s => s?.trim() ?? '');\n\n  // Monta objeto UTM respeitando a ordem pedida\n  const utms = {};\n  UTM_KEYS.forEach((key, idx) => {\n    utms[key] = parts[idx] ?? '';\n  });\n\n  // Retorna o item com os campos adicionados\n  return {\n    json: {\n      ...json,\n      // adiciona também como campos \"flat\" para facilitar mapeamentos\n      ...utms,\n      // e um bloco agrupado\n      utms,\n      // ecoa o sck lido (útil para debug)\n      _sck_raw: rawSck,\n      _sck_decoded: sckValue,\n    },\n    binary,\n  };\n});\n"
      },
