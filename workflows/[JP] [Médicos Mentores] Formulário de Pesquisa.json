    {
      "parameters": {
        "jsCode": "// Pegando a entrada\nconst inputData = $input.item.json;\n\n// Mapas de conversão\nconst atuaMap = {\n  \"1\": \"Sim, sou médico\",\n  \"2\": \"Sim, sou dentista\",\n  \"3\": \"Sim, sou nutricionista\",\n  \"4\": \"Sim, sou outro profissional de saúde\",\n  \"5\": \"Não atuo na área da saúde\"\n};\n\nconst clinicaMap = {\n  \"1\": \"Sim, fatura acima de R$50k/mês\",\n  \"2\": \"Sim, fatura acima de R$100k/mês\",\n  \"3\": \"Sim, fatura acima de R$200k/mês\",\n  \"4\": \"Não possuo consultório ou clínica\"\n};\n\nconst tempoMap = {\n  \"1\": \"Menos de 2 horas\",\n  \"2\": \"Entre 2 e 5 horas\",\n  \"3\": \"Entre 5 e 10 horas\",\n  \"4\": \"Mais de 10 horas\"\n};\n\nconst mentoriaMap = {\n  \"1\": \"Sim, já tenho e está funcionando\",\n  \"2\": \"Sim, mas ainda não está estruturado\",\n  \"3\": \"Estou começando agora\",\n  \"4\": \"Não tenho nenhum programa ainda\"\n};\n\nconst impedeMap = {\n  \"1\": \"Não sei como estruturar e precificar o programa\",\n  \"2\": \"Não sei como encontrar e abordar os primeiros clientes\",\n  \"3\": \"Acredito que não tenho autoridade ou audiência suficiente\",\n  \"4\": \"Não tenho tempo para montar e entregar isso\",\n  \"5\": \"Tenho medo de não conseguir gerar resultado para o mentorado\"\n};\n\nconst buscaaulaMap = {\n  \"1\": \"Entender se mentoria faz sentido para o meu perfil\",\n  \"2\": \"Estruturar meu primeiro programa educacional\",\n  \"3\": \"Aprender a vender e precificar melhor\",\n  \"4\": \"Escalar uma mentoria que já existe\"\n};\n\n// Resultado\nconst result = {\n  telefone: inputData.telefone,\n  atua: atuaMap[inputData.atua] || inputData.atua,\n  clinica: clinicaMap[inputData.clinica] || inputData.clinica,\n  tempo: tempoMap[inputData.tempo] || inputData.tempo,\n  mentoria: mentoriaMap[inputData.mentoria] || inputData.mentoria,\n  impede: impedeMap[inputData.impede] || inputData.impede,\n  buscaaula: buscaaulaMap[inputData.buscaaula] || inputData.buscaaula\n};\n\n// Retornar resultado\nreturn [\n  {\n    json: result\n  }\n];"
      },
