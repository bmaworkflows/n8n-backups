      "name": "recebe agendamento"
    },
    {
      "parameters": {
        "jsCode": "// Extrair start_time do payload do Calendly\nconst startTime = new Date($input.first().json.collection[0].start_time);\nconst now = new Date();\n\n// Manhã do dia da reunião = 08:00 BRT (11:00 UTC)\nconst morningOfDay = new Date(startTime);\nmorningOfDay.setUTCHours(11, 0, 0, 0);\n\n// Se a reunião é antes das 8h BRT, ajustar para não ficar depois do start_time\nif (morningOfDay >= startTime) {\n  morningOfDay.setUTCHours(8, 0, 0, 0); // fallback 05:00 UTC = 02:00 BRT... \n  // Na verdade se a reunião é de manhã cedo, a msg da manhã vira o próprio horário\n  morningOfDay.setTime(Math.min(morningOfDay.getTime(), startTime.getTime() - 60 * 60 * 1000));\n}\n\nconst h = 60 * 60 * 1000;   // 1 hora em ms\nconst d = 24 * h;            // 1 dia em ms\n\n// Alvos de envio de cada mensagem\nconst targets = {\n  delay_msg1: now,                                          // Imediata\n  delay_msg2: new Date(startTime.getTime() - 12 * h),      // 12h antes\n  delay_msg3: morningOfDay,                                 // Manhã do dia\n  delay_msg4: new Date(startTime.getTime() + 6 * h),       // 6h depois\n  delay_msg5: new Date(startTime.getTime() + 24 * h),      // 24h depois\n  delay_msg6: new Date(startTime.getTime() + 36 * h),      // 36h depois\n  delay_msg7: new Date(startTime.getTime() + 3 * d),       // 3 dias depois\n  delay_msg8: new Date(startTime.getTime() + 5 * d),       // 5 dias depois\n};\n\nconst result = {\n  start_time: startTime.toISOString(),\n  now_brt: new Date(now.getTime() - 3 * h).toISOString(),\n};\n\nfor (const [key, target] of Object.entries(targets)) {\n  const diffMinutes = Math.round((target.getTime() - now.getTime()) / 60000);\n  result[key] = Math.max(0, diffMinutes);\n}\n\nreturn [{ json: result }];"
      },
